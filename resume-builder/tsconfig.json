{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
	"composite": true,
	"declaration": false,	
	"emitDeclarationOnly": false,
	"outDir": "./dist",
	"rootDir": "./src",
	"baseUrl":".",
	"paths":{
		"@/*" : [ "src/*"],
		"@backend/*" : ["src/backend/*"],
		"@frontend/*" : ["src/frontend/*"],
		"@shared/*" : ["src/shared/*"]
	}
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}

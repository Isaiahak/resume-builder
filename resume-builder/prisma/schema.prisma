generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Keyword {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  category     Category
  skillType    String
  importance   Int
  bulletLinks  BulletKeyword[]
  projectLinks Project[]       @relation("KeywordToProject")
}

model BulletPoint {
  id           Int             @id @default(autoincrement())
  content      String
  projectId    Int
  projectType  ProjectType
  category     Category
  skillType    SkillType
  keywordLinks BulletKeyword[]
  project      Project         @relation(fields: [projectId], references: [id])
}

model Project {
  id          Int                 @id @default(autoincrement())
  name        String              @unique
  description String
  startDate   DateTime
  endDate     DateTime
  type        ProjectType
  bullets     BulletPoint[]
  categories  ProjectCategories[]
  keyword     Keyword[]           @relation("KeywordToProject")
}

model BulletKeyword {
  bulletId  Int
  keywordId Int
  keyword   Keyword     @relation(fields: [keywordId], references: [id])
  bullet    BulletPoint @relation(fields: [bulletId], references: [id])

  @@id([bulletId, keywordId])
}

model ProjectCategories {
  id        Int      @id @default(autoincrement())
  projectId Int
  category  Category
  project   Project  @relation(fields: [projectId], references: [id])
}

enum SkillType {
  HARD
  SOFT
}

enum Category {
  FRONTEND
  BACKEND
  DEVOPS
  DATA
  ML
  MANAGEMENT
  DESIGN
  TESTING
  OTHER
}

enum ProjectType {
  JOB
  PROJECT
}

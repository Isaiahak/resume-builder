generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum SkillType {
  HARD
  SOFT
}

enum Category {
  FRONTEND
  BACKEND
  DEVOPS
  DATA
  ML
  MANAGEMENT
  DESIGN
  TESTING
  OTHER
}

enum ProjectType {
  JOB
  PROJECT
}

model Keyword {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  category     Category
  skillType    String
  importance   Int
  bulletLinks  BulletKeyword[]
  projectLinks Project[]
}

model BulletPoint {
  id      Int    @id @default(autoincrement())
  content String

  projectId    Int
  projectType  ProjectType
  project      Project         @relation(fields: [projectId], references: [id]) // or relation if you expand later
  category     Category
  skillType    SkillType
  keywordLinks BulletKeyword[]
}

model Project {
  id          Int                 @id @default(autoincrement())
  name        String
  description String
  duration    DateTime
  type        ProjectType
  categories  ProjectCategories[]
  keyword     Keyword[]
  bullets     BulletPoint[]
}

model BulletKeyword {
  bulletId  Int
  keywordId Int

  bullet  BulletPoint @relation(fields: [bulletId], references: [id])
  keyword Keyword     @relation(fields: [keywordId], references: [id])

  @@id([bulletId, keywordId])
}

model ProjectCategories {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  category  Category
}
